;; Null + empty-collection decode. kx copies KDB+ payloads verbatim and
;; re-tags them; rayforce's null sentinels (INT64_MIN, NaN, ...) match KDB+'s,
;; so typed nulls should round-trip to rayforce nulls.

(set h (kxconnect kxhost kxport))

;; typed null atoms
(nil? (kxsend h "0N"))  -- true
(nil? (kxsend h "0Nh")) -- true
(nil? (kxsend h "0Ni")) -- true
(nil? (kxsend h "0n"))  -- true

;; empty typed vectors
(count (kxsend h "`long$()"))  -- 0
(count (kxsend h "`float$()")) -- 0
(count (kxsend h "0#`sym"))    -- 0

;; a null inside a vector survives
(nil? (at (kxsend h "1 0N 3") 1)) -- true

(kxclose h)
