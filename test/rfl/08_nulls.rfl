;; Null + empty-collection decode. q copies Q payloads verbatim and
;; re-tags them; rayforce's null sentinels (INT64_MIN, NaN, ...) match Q's,
;; so typed nulls should round-trip to rayforce nulls.

(set h (qconnect qhost qport))

;; typed null atoms
(nil? (qsend h "0N"))  -- true
(nil? (qsend h "0Nh")) -- true
(nil? (qsend h "0Ni")) -- true
(nil? (qsend h "0n"))  -- true

;; empty typed vectors
(count (qsend h "`long$()"))  -- 0
(count (qsend h "`float$()")) -- 0
(count (qsend h "0#`sym"))    -- 0

;; a null inside a vector survives
(nil? (at (qsend h "1 0N 3") 1)) -- true

(qclose h)
