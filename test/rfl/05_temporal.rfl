;; Temporal decode coverage (date / time / timestamp). kx copies the raw
;; KDB+ payload and re-tags it; these assertions confirm the epoch and width
;; line up with rayforce's own temporal types.

(set h (kxconnect kxhost kxport))

;; date atom + vector
(kxsend h "2025.01.01")            -- 2025.01.01
(kxsend h "2025.01.01 2025.01.02") -- [2025.01.01 2025.01.02]

;; time atom
(kxsend h "12:34:56.000") -- 12:34:56.000

;; timestamp atom
(kxsend h "2025.01.01D12:00:00.000000000") -- 2025.01.01D12:00:00.000000000

(kxclose h)
