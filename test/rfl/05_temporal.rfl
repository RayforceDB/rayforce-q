;; Temporal decode coverage (date / time / timestamp). q copies the raw
;; Q payload and re-tags it; these assertions confirm the epoch and width
;; line up with rayforce's own temporal types.

(set h (qconnect qhost qport))

;; date atom + vector
(qsend h "2025.01.01")            -- 2025.01.01
(qsend h "2025.01.01 2025.01.02") -- [2025.01.01 2025.01.02]

;; time atom
(qsend h "12:34:56.000") -- 12:34:56.000

;; timestamp atom
(qsend h "2025.01.01D12:00:00.000000000") -- 2025.01.01D12:00:00.000000000

(qclose h)
