;; Connection lifecycle and basic round-trips against a live q server.
;; qhost / qport are injected by the test driver (--host/--port).

(set h (qconnect qhost qport))

;; A handle is a non-negative integer slot.
(>= h 0) -- true

;; Basic synchronous query evaluation.
(qsend h "1+2") -- 3
(qsend h "first 1 2 3") -- 1
(qsend h "count til 10") -- 10

(qclose h)

;; Sending on a closed handle is a transport error.
(set h2 (qconnect qhost qport))
(qclose h2)
(qsend h2 "1+1") !- handle

;; Connecting to a closed port fails at the socket level.
(qconnect qhost 1) !- connect
