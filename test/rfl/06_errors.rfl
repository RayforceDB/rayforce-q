;; Server-side error decode: a q error response (-128) must surface as a
;; rayforce error carrying the q error text.
;;
;; Note: ray_fmt renders an error by its *code*, and the rayforce error code
;; is short (longer Q error text is truncated in the formatted display),
;; so these assertions use short error tokens.

(set h (qconnect qhost qport))

;; explicit q signal: 'myerr  -> error text "myerr"
(qsend h "'myerr") !- myerr

;; type error from a bad operation
(qsend h "`a+1") !- type

;; undefined variable -> q signals the name
(qsend h "xyzzy") !- xyzzy

;; the connection stays usable after a server error
(qsend h "2+2") -- 4

(qclose h)
