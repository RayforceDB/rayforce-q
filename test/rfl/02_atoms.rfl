;; Atom decode coverage: each q expression returns a scalar that q must
;; decode into the matching rayforce atom. Compared by formatted value.

(set h (qconnect qhost qport))

;; integers: long / int / short
(qsend h "42")  -- 42
(qsend h "42i") -- 42
(qsend h "42h") -- 42

;; floats: float / real
(qsend h "3.25")  -- 3.25
(qsend h "3.25e") -- 3.25

;; booleans
(qsend h "1b") -- true
(qsend h "0b") -- false

;; byte
(qsend h "0x2a") -- 0x2a

;; char atom (q "z" is a single char)
(qsend h "\"z\"") -- "z"

;; symbol atom
(qsend h "`abc") -- 'abc

(qclose h)
