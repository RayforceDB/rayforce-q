;; Authentication. The driver starts a second q with `-u users` on qauthport;
;; quser/qpass are the valid credentials it injects.

;; valid credentials -> a usable connection
(set h (qconnect qhost qauthport quser qpass))
(>= h 0) -- true
(qsend h "6*7") -- 42
(qclose h)

;; wrong password -> the server rejects the login (closes the socket mid
;; handshake, so the capability read fails)
(qconnect qhost qauthport quser "wrongpass") !- auth

;; no credentials at all against an auth server -> rejected
(qconnect qhost qauthport) !- auth
