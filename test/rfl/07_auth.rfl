;; Authentication. The driver starts a second q with `-u users` on kxauthport;
;; kxuser/kxpass are the valid credentials it injects.

;; valid credentials -> a usable connection
(set h (kxconnect kxhost kxauthport kxuser kxpass))
(>= h 0) -- true
(kxsend h "6*7") -- 42
(kxclose h)

;; wrong password -> the server rejects the login (closes the socket mid
;; handshake, so the capability read fails)
(kxconnect kxhost kxauthport kxuser "wrongpass") !- auth

;; no credentials at all against an auth server -> rejected
(kxconnect kxhost kxauthport) !- auth
