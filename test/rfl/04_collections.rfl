;; Nested structures: general list, table, dict.

(set h (qconnect qhost qport))

;; mixed general list -> rayforce list
(qsend h "(1;`a;1.5)") -- (list 1 'a 1.5)

;; table -> rayforce table (compared whole, including column types)
(qsend h "([] a:1 2 3; b:`x`y`z)") -- (table ['a 'b] (list [1 2 3] ['x 'y 'z]))

;; empty-ish / single-column table
(qsend h "([] x:1 2)") -- (table ['x] (list [1 2]))

;; dict -> native rayforce dict (decoded via ray_dict_new)
(qsend h "`a`b!1 2") -- (dict ['a 'b] [1 2])

(qclose h)
